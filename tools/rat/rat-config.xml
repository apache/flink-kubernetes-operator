<!--
  apache-rat configuration for the flink-kubernetes-operator project.

  This file replaces the inline <families> / <licenses> / <approvedLicenses>
  parameters in the root pom.xml, which were deprecated in apache-rat-plugin
  0.17 ("Use specific configuration under <configuration>. See configuration
  file documentation."). The pom now references this file via the plugin's
  <configs> parameter and disables the bundled default configuration via
  <configurationNoDefaults>true</configurationNoDefaults>, so this is the
  ONLY ruleset RAT loads.

  Strict Apache License 2.0 enforcement
  - Single recognised family: AL (Apache License).
  - Single recognised license:    AL2.0 (Apache License 2.0), matched on the
    canonical ASF source-header opener
    "Licensed to the Apache Software Foundation (ASF) under one".
  - Single approved family: AL.
  Any source file that does not contain that header text is reported as
  "Unknown license (Unapproved)" and trips the Unapproved:0 counter declared
  in the pom, failing the build.

  Schema reference: apache-rat-core/org/apache/rat/default.xml
                    https://creadur.apache.org/rat/apache-rat-plugin/check-mojo.html
-->
<rat-config>
    <families>
        <family id="AL" name="Apache License" />
    </families>
    <licenses>
        <license family="AL" id="AL2.0" name="Apache License 2.0">
            <text>Licensed to the Apache Software Foundation (ASF) under one</text>
        </license>
    </licenses>
    <approved>
        <family license_ref="AL" />
    </approved>
</rat-config>

